{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "vendor/example-block",
    "title": "Example Block",
    "category": "imagewize",
    "icon": "grid-view",
    "description": "Block description.",
    "keywords": [],
    "example": {},
    "textdomain": "vendor",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./editor.css",
    "style": "file:./style.css",
    "viewScript": "file:./view.js",
    "supports": {
        "align": ["wide", "full"],
        "anchor": true,
        "spacing": {
            "margin": true,
            "padding": true
        },
        "color": {
            "background": true,
            "text": true
        }
    },
    "attributes": {
        "align": {
            "type": "string",
            "default": "full"
        },
        "style": {
            "type": "object",
            "default": {
                "spacing": {
                    "margin": { "top": "0", "bottom": "0" }
                }
            }
        }
    }
}
